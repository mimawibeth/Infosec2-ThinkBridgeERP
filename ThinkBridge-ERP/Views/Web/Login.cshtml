@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Login";
    ViewData["HideLayout"] = true;
    ViewData["BodyClass"] = "login-page";
    var turnstileSiteKey = Configuration["Turnstile:SiteKey"] ?? string.Empty;
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/login.css" asp-append-version="true" />
}

<a href="/" class="back-to-home-btn">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Back to Home
</a>

<div class="login-container">
    <!-- Left Side - Branding -->
    <div class="login-branding">
        <div class="branding-content">
            <div class="logo">
                <img src="~/images/thinkBridge.png" alt="ThinkBridge" class="logo-icon" />
                <span class="logo-text"><span class="logo-think">Think</span><span
                    class="logo-bridge">Bridge</span></span>
                </div>
                <h1 class="branding-title">Enterprise Resource Planning Made Simple</h1>
                <p class="branding-description">
                    Streamline your business operations with our comprehensive ERP solution designed for modern teams.
                </p>
                <div class="feature-grid">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <rect x="3" y="3" width="7" height="7"></rect>
                                <rect x="14" y="3" width="7" height="7"></rect>
                                <rect x="14" y="14" width="7" height="7"></rect>
                                <rect x="3" y="14" width="7" height="7"></rect>
                            </svg>
                        </div>
                        <h3>Centralized Dashboard</h3>
                        <p>Monitor all projects from one place</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                                <line x1="8" y1="21" x2="16" y2="21"></line>
                                <line x1="12" y1="17" x2="12" y2="21"></line>
                            </svg>
                        </div>
                        <h3>Project Management</h3>
                        <p>Track progress efficiently</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </div>
                        <h3>Team Collaboration</h3>
                        <p>Work together seamlessly</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                            </svg>
                        </div>
                        <h3>Knowledge Base</h3>
                        <p>Access documentation easily</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <path d="M12 6v6l4 2"></path>
                            </svg>
                        </div>
                        <h3>Enterprise Security</h3>
                        <p>Role-based access control</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                            </svg>
                        </div>
                        <h3>Real-time Updates</h3>
                        <p>Stay informed instantly</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Login Form -->
        <div class="login-form-container">
            <div class="login-form-wrapper">
                <div class="login-logo-mobile">
                    <img src="~/images/thinkBridge.png" alt="ThinkBridge" class="logo-icon" />
                    <span class="logo-text"><span class="logo-think">Think</span><span
                        class="logo-bridge">Bridge</span></span>
                    </div>
                    <div class="login-header">
                        <h2>Welcome back</h2>
                        <p>Access your ThinkBridge ERP workspace.</p>
                    </div>

                    <form class="login-form" id="loginForm">
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" class="form-input" placeholder="Enter your email address" required />
                        </div>

                        <div class="form-group">
                            <label for="password">Password</label>
                            <div class="input-wrapper">
                                <input type="password" id="password" class="form-input" placeholder="Enter your password"
                                       required />
                                <button type="button" class="password-toggle" id="toggle-password">
                                    <svg class="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="form-group captcha-group">
                            <div id="login-turnstile" class="turnstile-widget"></div>
                        </div>

                        <div class="form-group error-message" id="errorMessage" style="display: none;">
                            <span class="error-text">Invalid password. Please try again.</span>
                        </div>

                        <div class="renew-subscription-cta" id="renewSubscriptionCta" style="display: none;">
                            <p class="renew-cta-text">Need access back to your workspace? Continue with secure renewal checkout.</p>
                            <button type="button" class="btn btn-secondary" id="renewSubscriptionBtn">Renew Subscription</button>
                        </div>

                        <div class="mfa-step" id="mfaStep" style="display: none;">
                            <div class="mfa-header">
                                <h3>Two-Factor Verification</h3>
                                <p id="mfaMessage">Enter the code from your authenticator app.</p>
                            </div>

                            <div class="mfa-enrollment" id="mfaEnrollment" style="display: none;">
                                <div class="mfa-enrollment-grid">
                                    <div class="mfa-qr-wrap">
                                        <img id="mfaQrImage" alt="Authenticator setup QR code" />
                                    </div>
                                    <div>
                                        <p class="mfa-setup-note">Scan the QR code in Google Authenticator (or any TOTP app), then enter the 6-digit code below.</p>
                                        <button type="button" class="link-button mfa-manual-toggle" id="mfaManualKeyToggle">Can't scan QR? Enter key manually</button>
                                        <div id="mfaManualKeyWrap" style="display: none;">
                                            <label for="mfaSecret" class="mfa-secret-label">Manual setup key</label>
                                            <input type="text" id="mfaSecret" class="form-input" readonly />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group" id="mfaTotpGroup">
                                <label for="mfaCode">Authenticator Code</label>
                                <input type="text" id="mfaCode" class="form-input" inputmode="numeric" autocomplete="one-time-code"
                                       placeholder="000000" maxlength="8" />
                            </div>

                            <div class="form-group" id="mfaBackupGroup" style="display: none;">
                                <label for="mfaBackupCode">Backup Code</label>
                                <input type="text" id="mfaBackupCode" class="form-input" autocomplete="one-time-code"
                                       placeholder="ABCD-EFGH" maxlength="20" />
                            </div>

                            <div class="mfa-links">
                                <button type="button" class="link-button" id="mfaToggleModeBtn">Use backup code instead</button>
                                <button type="button" class="link-button" id="mfaBackToLoginBtn">Back to login</button>
                            </div>
                        </div>

                        <a href="#" class="forgot-password-link" id="forgot-password-link">Forgot your password?</a>

                        <button type="submit" class="btn btn-primary btn-login" id="loginBtn">
                            Sign In
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        </button>
                    </form>

                    <div class="login-footer">
                        <p>Don't have an account? <a href="/Subscription/SignUp">Sign Up</a></p>
                    </div>
                </div>
                <div class="login-terms">
                    <p>By signing in, you agree to our <a href="#" id="terms-link">Terms</a> and <a href="#"
                                                                                                        id="privacy-link">Privacy Policy</a></p>
                    </div>
                </div>
            </div>

            <!-- Forgot Password Modal -->
            <div class="modal-overlay" id="forgot-password-modal">
                <div class="modal">
                    <div class="modal-header">
                        <h2>Reset Password</h2>
                        <button class="modal-close" data-modal-close>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                        </button>
                    </div>
                    <div class="modal-body">
                        <p class="forgot-password-description">Enter the email address associated with your account and we'll send
                            you a temporary password.</p>

                            <div id="forgot-password-form-container">
                                <div class="form-group">
                                    <label for="forgot-email">Email Address</label>
                                    <input type="email" id="forgot-email" class="form-input" placeholder="Enter your email address"
                                           required />
                                </div>
                                <div class="form-group captcha-group">
                                    <div id="forgot-turnstile" class="turnstile-widget"></div>
                                </div>
                                <div class="form-group error-message" id="forgot-error" style="display: none;">
                                    <span class="error-text" id="forgot-error-text"></span>
                                </div>
                            </div>

                            <div id="forgot-success-container" style="display: none;">
                                <div class="success-message">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                    </svg>
                                    <span id="forgot-success-text">A temporary password has been sent to your email. Please check your
                                        inbox.</span>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer" id="forgot-footer">
                                <button class="btn btn-secondary" data-modal-close>Cancel</button>
                                <button class="btn btn-primary" id="forgot-submit-btn">Send Reset Email</button>
                            </div>
                            <div class="modal-footer" id="forgot-done-footer" style="display: none;">
                                <button class="btn btn-primary" data-modal-close>Done</button>
                            </div>
                        </div>
                    </div>

                    <!-- Terms of Service Modal -->
                    <div class="modal-overlay" id="terms-modal">
                        <div class="modal modal-lg">
                            <div class="modal-header">
                                <h2>Terms of Service</h2>
                                <button class="modal-close" data-modal-close>
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                </button>
                            </div>
